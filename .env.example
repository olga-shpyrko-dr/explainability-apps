# ===========================================================================
# DataRobot core — always required
# ===========================================================================
DATAROBOT_API_TOKEN=your_token_here
DATAROBOT_ENDPOINT=https://app.eu.datarobot.com/api/v2

# ===========================================================================
# Explainability pipeline — pre-filled for this project
# ===========================================================================
# PROJECT_ID=6a22f2218f74af009899ddb1
# MODEL_ID=6a22f2ab13b0a82934ef1155
# DATASET_ID=6a2275eb1a27ddce9c076a03
# ROW_ID_COL=Policy_Number

# ===========================================================================
# LLM provider — configure ONE or MORE; the app will show available providers
# ===========================================================================

# --- Option 1: DataRobot LLM Gateway (recommended — uses DR API token above) ---
# Route: {endpoint}/genai/llmgw/chat/completions
# Model IDs: Chat model ID column from docs.datarobot.com/en/docs/reference/gen-ai-ref/llm-availability.html
DR_GATEWAY_MODEL=azure/gpt-4o-mini
# Other examples:
#   azure/gpt-4o-2024-11-20
#   anthropic/claude-sonnet-4-6
#   vertex_ai/gemini-2.0-flash-001
#   bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Option 2: DataRobot deployed TextGen model ---
# DR_LLM_DEPLOYMENT_ID=your_textgen_deployment_id_here

# --- Option 3: Azure OpenAI ---
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_API_BASE=https://your-instance.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# --- Option 4: Anthropic (direct) ---
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ===========================================================================
# SQL Server export (scripts/export_to_sql.py) — Power BI path
# ===========================================================================
# SQL Server with SQL auth:
# SQL_CONNECTION_STRING=mssql+pyodbc://username:password@server/database?driver=ODBC+Driver+17+for+SQL+Server
# SQL Server with Windows auth:
# SQL_CONNECTION_STRING=mssql+pyodbc://@server/database?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
# Azure SQL:
# SQL_CONNECTION_STRING=mssql+pyodbc://username:password@server.database.windows.net/database?driver=ODBC+Driver+17+for+SQL+Server

# SQL_SCHEMA=dbo
# SQL_TABLE_PREFIX=explainability_

# Optional: path to training Excel for Lapse_ind outcome labels
# TRAINING_EXCEL_PATH=data/Protection_Lapse_2025_Training_exclUL_withReviews_exclNBLapse_excl5YrMaturities.xlsx
