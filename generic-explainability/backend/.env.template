# =============================================================================
# Generic Explainability App — .env template
# Copy to .env and fill in values for your use case.
# =============================================================================

# ---------------------------------------------------------------------------
# Data source: "datarobot" (default) or "csv"
# ---------------------------------------------------------------------------
DATA_SOURCE=datarobot

# CSV mode only — path to a pre-scored CSV with EXPLANATION_N_* columns
# CSV_PATH=data/scored_population.csv

# ---------------------------------------------------------------------------
# DataRobot credentials (required for data_source=datarobot)
# ---------------------------------------------------------------------------
DATAROBOT_API_TOKEN=
DATAROBOT_ENDPOINT=https://app.datarobot.com/api/v2

# ---------------------------------------------------------------------------
# Scoring pipeline
#
# Option A — Deployment (preferred):
#   Runs a BatchPredictionJob via the deployment. The deployment must have
#   SHAP prediction explanations enabled.
#
# Option B — Project + Model (fallback):
#   Used only when DEPLOYMENT_ID is not set. Uploads the scoring dataset to
#   the project, requests predictions, and initialises Prediction Explanations.
# ---------------------------------------------------------------------------
DEPLOYMENT_ID=                   # preferred — set this to use Option A

# PROJECT_ID=                    # fallback Option B
# MODEL_ID=                      # fallback Option B

SCORING_DATASET_ID=              # AI Catalog dataset ID to score
# TRAINING_DATASET_ID=           # optional — enables actual outcome rate in narrative

# ---------------------------------------------------------------------------
# Use case (optional — scopes the in-app dataset selector to one folder)
# ---------------------------------------------------------------------------
# DEFAULT_USE_CASE_ID=

# ---------------------------------------------------------------------------
# Column config
# ---------------------------------------------------------------------------
ROW_ID_COL=id                    # unique row identifier column
# PREDICTION_COL=                # auto-detected from first *_PREDICTION column
# OUTCOME_COL=                   # binary 0/1 outcome column in training data
MAX_EXPLANATIONS=4

# ---------------------------------------------------------------------------
# App metadata
# ---------------------------------------------------------------------------
APP_TITLE=Prediction Explainability
APP_SUBTITLE=
# optional — overrides dr.Dataset.name in the UI
# DATASET_DISPLAY_NAME=

# ---------------------------------------------------------------------------
# Tuning (safe to leave at defaults)
# ---------------------------------------------------------------------------
# COHORT_WARNING_MIN_ROWS=30
# TOP_FEATURES_PER_GROUP=5
# SCORE_HISTOGRAM_BINS=20
# NARRATIVE_MAX_TOKENS=700
# NARRATIVE_GROUPS_IN_PROMPT=6
# NARRATIVE_FEATURES_PER_GROUP=2

# ---------------------------------------------------------------------------
# LLM — pick one provider (at least one required for AI Narrative)
# ---------------------------------------------------------------------------

# DataRobot LLM Gateway (recommended if using DataRobot SaaS)
# DR_GATEWAY_MODEL=azure/gpt-4o-mini

# DataRobot deployed TextGen model
# DR_LLM_DEPLOYMENT_ID=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_BASE=
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT_NAME=

# Anthropic (direct API)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
