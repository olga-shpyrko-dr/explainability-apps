# =============================================================================
# Motor Claim Fraud Detection — example .env
# Copy to .env and fill in your DataRobot credentials.
# =============================================================================

DATA_SOURCE=datarobot

DATAROBOT_API_TOKEN=your_token_here
DATAROBOT_ENDPOINT=https://app.datarobot.com/api/v2

# ---------------------------------------------------------------------------
# Scoring pipeline — DEPLOYMENT_ID is preferred.
# If set, a BatchPredictionJob is used (faster, no PE initialisation needed).
# If omitted, falls back to PROJECT_ID + MODEL_ID via the Prediction Explanations API.
# ---------------------------------------------------------------------------
DEPLOYMENT_ID=6a4262b3824b9dae4e22d006

# Fallback (only needed when DEPLOYMENT_ID is not set)
# PROJECT_ID=6a42312643e91bbd48762db8
# MODEL_ID=6a42323c6d777a364c9d320e

SCORING_DATASET_ID=your_scoring_dataset_id
# TRAINING_DATASET_ID=your_training_dataset_id  # optional — enables confirmed fraud rate in narrative

USE_CASE_ID=6a4216dc84568468eaed3dee

# ---------------------------------------------------------------------------
# Column config
# ---------------------------------------------------------------------------
ROW_ID_COL=TRANSACTION_ID
# PREDICTION_COL=                # auto-detected from _PREDICTION suffix
OUTCOME_COL=CLAIM_STATUS         # 0/1 fraud label in training data
MAX_EXPLANATIONS=4

# ---------------------------------------------------------------------------
# App metadata
# ---------------------------------------------------------------------------
APP_TITLE=Motor Claim Fraud Detection — Explainability
APP_SUBTITLE=
DATASET_DISPLAY_NAME=            # optional — overrides dr.Dataset.name in the UI
DEFAULT_USE_CASE_ID=6a4216dc84568468eaed3dee  # scopes the dataset selector to this use case

# ---------------------------------------------------------------------------
# LLM — pick one provider
# ---------------------------------------------------------------------------
DR_GATEWAY_MODEL=azure/gpt-4o-mini
# DR_LLM_DEPLOYMENT_ID=...
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-sonnet-4-6
