# =============================================================================
# Generic Explainability App — Environment Configuration
# Copy to .env and fill in your values.
# =============================================================================

# ----------------------------------------------------------------------------
# Data source: "datarobot" (default) or "csv"
# ----------------------------------------------------------------------------
DATA_SOURCE=datarobot

# --- CSV mode (DATA_SOURCE=csv) ---
# CSV_PATH=data/scored_population.csv
# TRAINING_CSV_PATH=data/training_with_labels.csv

# --- DataRobot mode (DATA_SOURCE=datarobot) ---
DATAROBOT_API_TOKEN=your_token_here
DATAROBOT_ENDPOINT=https://app.datarobot.com/api/v2
PROJECT_ID=your_project_id
MODEL_ID=your_model_id
SCORING_DATASET_ID=your_scoring_dataset_id
# TRAINING_DATASET_ID=your_training_dataset_id  # optional

# ----------------------------------------------------------------------------
# Column configuration
# ----------------------------------------------------------------------------
ROW_ID_COL=id
# PREDICTION_COL=target_PREDICTION    # auto-detected if not set
# OUTCOME_COL=target                  # binary 0/1 column in training data
MAX_EXPLANATIONS=4

# ----------------------------------------------------------------------------
# Application metadata
# ----------------------------------------------------------------------------
APP_TITLE=Prediction Explainability
APP_SUBTITLE=

# ----------------------------------------------------------------------------
# Tuning (optional — defaults shown)
# ----------------------------------------------------------------------------
# COHORT_WARNING_MIN_ROWS=30
# TOP_FEATURES_PER_GROUP=5
# SCORE_HISTOGRAM_BINS=20
# NARRATIVE_MAX_TOKENS=700
# NARRATIVE_GROUPS_IN_PROMPT=6
# NARRATIVE_FEATURES_PER_GROUP=2

# ----------------------------------------------------------------------------
# LLM providers — configure at least one for the narrative feature
# ----------------------------------------------------------------------------

# DataRobot LLM Gateway (uses DATAROBOT_API_TOKEN above)
# DR_GATEWAY_MODEL=azure-openai/gpt-4o-mini

# DataRobot deployed TextGen model
# DR_LLM_DEPLOYMENT_ID=your_deployment_id

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_BASE=https://your-instance.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Anthropic (direct API)
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-sonnet-4-6
